{
  "manifest_version": 3,
  "name": "底稿小幫手",
  "version": "1.0",
  "description": "工作底稿常用文字管理工具，一鍵複製你需要的文字！",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "文字庫"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
